{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Time Drift Analysis (Fine-grained Segments + Holdout)\n",
    "\n",
    "依據 `strategy/time_drift.md`：\n",
    "- Drift track：以 `step` 細分段做高解析 drift 分析\n",
    "- Model track：保留最終 holdout 尾段（最後 15% unique steps）\n",
    "\n",
    "本 notebook 針對大資料做了兩個保護：\n",
    "1. 全量統計只做輕量聚合\n",
    "2. 視覺化預設用分層抽樣"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import seaborn as sns\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "sns.set_theme(style='whitegrid')\n",
    "pd.set_option('display.max_columns', 200)\n",
    "pd.set_option('display.float_format', lambda x: f'{x:,.6f}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 0) Config"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "DATA_PATH = '../Transactions Data.csv'\n",
    "TARGET = 'isFraud'\n",
    "STEP_COL = 'step'\n",
    "TYPE_COL = 'type'\n",
    "\n",
    "# Drift track: 細分段數（建議 12~20）\n",
    "N_SEGMENTS = 12\n",
    "\n",
    "# Model track: 最終 holdout 比例（尾段）\n",
    "HOLDOUT_RATIO = 0.15\n",
    "\n",
    "# 視覺化抽樣設定\n",
    "USE_VIZ_SAMPLE = True\n",
    "VIZ_SAMPLE_SIZE = 400_000\n",
    "RANDOM_STATE = 42\n",
    "\n",
    "# 是否讀全量（如果機器撐不住可先改成 True + SAMPLE_FRAC）\n",
    "USE_FAST_SAMPLE_FOR_DEV = False\n",
    "SAMPLE_FRAC = 0.2"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1) Load Data"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "df = pd.read_csv(DATA_PATH)\n",
    "\n",
    "if USE_FAST_SAMPLE_FOR_DEV:\n",
    "    # 開發模式：先抽樣測流程，不建議用於最終結論\n",
    "    df = df.sample(frac=SAMPLE_FRAC, random_state=RANDOM_STATE).copy()\n",
    "\n",
    "df = df.sort_values(STEP_COL).reset_index(drop=True)\n",
    "print('Shape:', df.shape)\n",
    "print('Fraud rate:', df[TARGET].mean())\n",
    "df.head()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2) Build Segments (Drift Track + Holdout Track)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "steps_sorted = np.sort(df[STEP_COL].unique())\n",
    "\n",
    "# Holdout track (最後 15% unique steps)\n",
    "holdout_cut_idx = int(len(steps_sorted) * (1 - HOLDOUT_RATIO))\n",
    "holdout_min_step = steps_sorted[holdout_cut_idx] if holdout_cut_idx < len(steps_sorted) else steps_sorted[-1]\n",
    "\n",
    "df['is_holdout_test'] = (df[STEP_COL] >= holdout_min_step).astype(int)\n",
    "\n",
    "# Drift track: 用 unique steps 做 quantile-like 分段\n",
    "step_to_rank = pd.Series(np.arange(len(steps_sorted)), index=steps_sorted)\n",
    "rank = df[STEP_COL].map(step_to_rank).astype(int)\n",
    "df['time_segment'] = pd.cut(rank, bins=N_SEGMENTS, labels=False, include_lowest=True)\n",
    "df['time_segment'] = df['time_segment'].astype(int)\n",
    "\n",
    "print('Unique steps:', len(steps_sorted))\n",
    "print('Holdout min step:', holdout_min_step)\n",
    "display(df[['time_segment', 'is_holdout_test']].describe(include='all'))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Segment boundary table\n",
    "segment_bounds = df.groupby('time_segment')[STEP_COL].agg(['min', 'max', 'nunique']).reset_index()\n",
    "segment_bounds.columns = ['time_segment', 'step_min', 'step_max', 'step_unique_count']\n",
    "segment_bounds"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3) Lightweight Full-data Drift Stats"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 基本 label drift（每段）\n",
    "label_drift = df.groupby('time_segment').agg(\n",
    "    rows=(TARGET, 'size'),\n",
    "    fraud_rate=(TARGET, 'mean'),\n",
    "    fraud_count=(TARGET, 'sum'),\n",
    "    flagged_rate=('isFlaggedFraud', 'mean')\n",
    ").reset_index()\n",
    "\n",
    "label_drift['fraud_rate_change_vs_prev'] = label_drift['fraud_rate'].pct_change()\n",
    "label_drift"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# type 組成漂移\n",
    "type_share = (\n",
    "    df.groupby(['time_segment', TYPE_COL]).size()\n",
    "      .rename('cnt')\n",
    "      .reset_index()\n",
    ")\n",
    "type_share['segment_total'] = type_share.groupby('time_segment')['cnt'].transform('sum')\n",
    "type_share['type_share'] = type_share['cnt'] / type_share['segment_total']\n",
    "\n",
    "type_share.head(20)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 數值分布漂移（分位數）\n",
    "df['deltaOrig'] = df['oldbalanceOrg'] - df['newbalanceOrig']\n",
    "df['deltaDest'] = df['newbalanceDest'] - df['oldbalanceDest']\n",
    "df['log_amount'] = np.log1p(df['amount'])\n",
    "\n",
    "num_cols = ['log_amount', 'oldbalanceOrg', 'newbalanceOrig', 'oldbalanceDest', 'newbalanceDest', 'deltaOrig', 'deltaDest']\n",
    "\n",
    "quantile_rows = []\n",
    "for seg, g in df.groupby('time_segment'):\n",
    "    row = {'time_segment': seg, 'rows': len(g)}\n",
    "    for c in num_cols:\n",
    "        row[f'{c}_median'] = g[c].median()\n",
    "        row[f'{c}_p90'] = g[c].quantile(0.90)\n",
    "        row[f'{c}_p99'] = g[c].quantile(0.99)\n",
    "    quantile_rows.append(row)\n",
    "\n",
    "quantile_drift = pd.DataFrame(quantile_rows).sort_values('time_segment')\n",
    "quantile_drift.head()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4) Holdout Track Summary (Model Evaluation Reference)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "holdout_summary = df.groupby('is_holdout_test').agg(\n",
    "    rows=(TARGET, 'size'),\n",
    "    fraud_rate=(TARGET, 'mean'),\n",
    "    flagged_rate=('isFlaggedFraud', 'mean'),\n",
    "    step_min=(STEP_COL, 'min'),\n",
    "    step_max=(STEP_COL, 'max')\n",
    ").reset_index()\n",
    "holdout_summary['split'] = holdout_summary['is_holdout_test'].map({0: 'pre-holdout', 1: 'holdout-test'})\n",
    "holdout_summary[['split', 'rows', 'fraud_rate', 'flagged_rate', 'step_min', 'step_max']]"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5) Drift Warnings (Rule-based)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "warnings_list = []\n",
    "\n",
    "# 1) Label drift warning: 相鄰段 fraud rate 變化 > 20%\n",
    "tmp = label_drift.copy()\n",
    "tmp['abs_change'] = tmp['fraud_rate'].pct_change().abs()\n",
    "hit = tmp[tmp['abs_change'] > 0.20]\n",
    "if len(hit) > 0:\n",
    "    warnings_list.append(f'Label drift warning segments: {hit["time_segment"].tolist()}')\n",
    "\n",
    "# 2) Category drift warning: 任一 type 在相鄰段占比變化 > 5pp\n",
    "pivot_share = type_share.pivot(index='time_segment', columns=TYPE_COL, values='type_share').fillna(0).sort_index()\n",
    "share_diff = pivot_share.diff().abs()\n",
    "if (share_diff > 0.05).any().any():\n",
    "    warnings_list.append('Category drift warning: at least one type share changed > 5 percentage points between adjacent segments')\n",
    "\n",
    "# 3) Amount drift warning: log_amount median 或 p90 相鄰段變化 > 15%\n",
    "q = quantile_drift.sort_values('time_segment').copy()\n",
    "q['med_change'] = q['log_amount_median'].pct_change().abs()\n",
    "q['p90_change'] = q['log_amount_p90'].pct_change().abs()\n",
    "if ((q['med_change'] > 0.15) | (q['p90_change'] > 0.15)).any():\n",
    "    warnings_list.append('Amount drift warning: log_amount median or p90 changed > 15% between adjacent segments')\n",
    "\n",
    "if warnings_list:\n",
    "    print('Drift warnings found:')\n",
    "    for w in warnings_list:\n",
    "        print('-', w)\n",
    "else:\n",
    "    print('No rule-based drift warnings triggered by current thresholds.')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6) Visualization (Stratified Sample for Stability)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "if USE_VIZ_SAMPLE:\n",
    "    # 依 target 分層抽樣，避免 fraud 幾乎看不到\n",
    "    n_total = min(VIZ_SAMPLE_SIZE, len(df))\n",
    "    frac = n_total / len(df)\n",
    "\n",
    "    sampled = (\n",
    "        df.groupby(TARGET, group_keys=False)\n",
    "          .apply(lambda x: x.sample(frac=frac, random_state=RANDOM_STATE) if len(x) > 0 else x)\n",
    "          .reset_index(drop=True)\n",
    "    )\n",
    "else:\n",
    "    sampled = df.copy()\n",
    "\n",
    "print('Viz sample shape:', sampled.shape, '| fraud rate:', sampled[TARGET].mean())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# fraud rate over segment + rolling mean\n",
    "plot_df = label_drift.sort_values('time_segment').copy()\n",
    "plot_df['fraud_rate_roll3'] = plot_df['fraud_rate'].rolling(3, min_periods=1).mean()\n",
    "\n",
    "plt.figure(figsize=(10,4))\n",
    "sns.lineplot(data=plot_df, x='time_segment', y='fraud_rate', marker='o', label='fraud_rate')\n",
    "sns.lineplot(data=plot_df, x='time_segment', y='fraud_rate_roll3', marker='o', label='rolling_mean(3)')\n",
    "plt.title('Fraud Rate by Fine-grained Time Segment')\n",
    "plt.xlabel('time_segment')\n",
    "plt.ylabel('fraud_rate')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# log_amount distribution by segment (sampled)\n",
    "plt.figure(figsize=(11,4))\n",
    "sns.boxplot(data=sampled, x='time_segment', y='log_amount', showfliers=False)\n",
    "plt.title('log1p(amount) by time segment (sampled)')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# type share by segment\n",
    "plt.figure(figsize=(12,5))\n",
    "stack_df = type_share.pivot(index='time_segment', columns=TYPE_COL, values='type_share').fillna(0).sort_index()\n",
    "stack_df.plot(kind='bar', stacked=True, figsize=(12,5), colormap='tab20')\n",
    "plt.title('Transaction Type Share by Time Segment')\n",
    "plt.xlabel('time_segment')\n",
    "plt.ylabel('share')\n",
    "plt.legend(title='type', bbox_to_anchor=(1.02, 1), loc='upper left')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7) Export Tables (Optional)"
   ]
  },
  {
   "cell_type": "code",
